<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laboratorio de Prompts ✨</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #0f172a;
            color: #f8fafc;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .loader {
            border: 3px solid rgba(255,255,255,0.1);
            border-top-color: #00E676;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body class="antialiased p-4 md:p-8 min-h-screen flex items-center justify-center">

    <main class="w-full max-w-6xl mx-auto">
        <!-- SECCIÓN: Laboratorio de Prompts ✨ impulsado por Gemini API -->
        <section class="bg-slate-900 p-6 md:p-10 rounded-2xl border border-[#00E676]/50 shadow-2xl relative overflow-hidden">
            <div class="absolute -top-10 -right-10 w-40 h-40 bg-[#00E676] rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
            <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-[#D500F9] rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
            
            <div class="relative z-10">
                <header class="mb-8 border-b border-slate-700 pb-6">
                    <div class="inline-block bg-slate-800 rounded-full px-3 py-1 text-xs font-semibold text-[#00E676] mb-3 border border-[#00E676]/30">
                        🤖 Potenciado por Gemini API
                    </div>
                    <h1 class="text-3xl md:text-4xl font-bold mb-2 flex items-center gap-3 text-white">
                        Laboratorio de Prompts ✨
                    </h1>
                    <p class="text-slate-300">
                        Escribe una idea básica y selecciona los atajos que quieras. Nuestra IA aplicará los trucos y te mostrará el prompt optimizado junto con un ejemplo de cómo respondería.
                    </p>
                </header>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <!-- Controles -->
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-bold text-[#00E676] mb-2" for="base-prompt">1. Tu idea básica:</label>
                            <textarea id="base-prompt" rows="3" class="w-full bg-slate-800 border border-slate-600 rounded-lg p-3 text-white focus:outline-none focus:border-[#00E676] resize-none" placeholder="Ej: Explícame qué es la física cuántica..."></textarea>
                        </div>
                        
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-bold text-[#D500F9] mb-2">2. Nivel de Simplicidad:</label>
                                <select id="modifier-ls" class="w-full bg-slate-800 border border-slate-600 rounded-lg p-2 text-white focus:outline-none focus:border-[#D500F9]">
                                    <option value="Normal">Normal (Sin atajo)</option>
                                    <option value="ELI5">ELI5 (Como a un niño de 5 años)</option>
                                    <option value="LS10">LS10 (Nivel 10 años)</option>
                                    <option value="LS-PhD">LS-PhD (Nivel Doctorado Universitario)</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-[#0056D2] mb-2">3. Tono / Rol:</label>
                                <select id="modifier-tone" class="w-full bg-slate-800 border border-slate-600 rounded-lg p-2 text-white focus:outline-none focus:border-[#0056D2]">
                                    <option value="Normal">Normal (Asistente)</option>
                                    <option value="/human">/human (Conversacional, natural)</option>
                                    <option value="Abogado del Diablo">Abogado del Diablo (Crítico)</option>
                                    <option value="Sin florituras">Sin florituras (Directo al grano)</option>
                                </select>
                            </div>
                            <div class="col-span-2">
                                <label class="block text-sm font-bold text-[#FF6D00] mb-2">4. Formato de Salida:</label>
                                <select id="modifier-format" class="w-full bg-slate-800 border border-slate-600 rounded-lg p-2 text-white focus:outline-none focus:border-[#FF6D00]">
                                    <option value="Texto Libre">Texto libre (Predeterminado)</option>
                                    <option value="Formato Tabla">[Formato Tabla]</option>
                                    <option value="Paso a Paso">[Paso a Paso]</option>
                                    <option value="TL;DR">[TL;DR] (Resumen de una frase)</option>
                                </select>
                            </div>
                        </div>

                        <button id="btn-optimize" onclick="runPromptLab()" class="w-full bg-gradient-to-r from-[#00E676] to-[#0056D2] text-white font-bold py-3 px-6 rounded-lg shadow-lg hover:shadow-[#00E676]/50 transition-all flex items-center justify-center gap-2">
                            <span>Transformar Prompt ✨</span>
                        </button>
                        <div id="error-message" class="text-red-400 text-sm hidden">Ocurrió un error al contactar con la API. Reintentando...</div>
                    </div>

                    <!-- Resultados -->
                    <div class="bg-slate-800 p-6 rounded-xl border border-slate-700 h-full flex flex-col min-h-[400px]">
                        <h3 class="text-lg font-bold text-white mb-4 border-b border-slate-600 pb-2">Resultado del Laboratorio</h3>
                        
                        <div id="lab-loading" class="hidden flex-1 flex flex-col items-center justify-center gap-4">
                            <div class="loader"></div>
                            <p class="text-slate-400 text-sm animate-pulse">Gemini está analizando los atajos...</p>
                        </div>

                        <div id="lab-results" class="hidden flex-1 flex flex-col gap-4 overflow-y-auto max-h-[500px]">
                            <div>
                                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Prompt Optimizado que debes usar:</h4>
                                <div id="result-prompt" class="bg-slate-900 p-3 rounded text-[#00E676] text-sm font-mono border border-slate-700"></div>
                            </div>
                            <div class="flex-1">
                                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Ejemplo de Respuesta Generada:</h4>
                                <div id="result-response" class="bg-slate-700/50 p-4 rounded-lg text-slate-200 text-sm h-full prose prose-invert max-w-none"></div>
                            </div>
                        </div>

                        <div id="lab-empty" class="flex-1 flex items-center justify-center text-slate-500 text-sm text-center">
                            Escribe una idea, elige tus modificadores y pulsa en "Transformar Prompt ✨" para ver la magia de Gemini.
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        // --- GEMINI API INTEGRATION ---
        const apiKey = ""; // API Key proveída por el entorno de ejecución
        
        async function fetchWithRetry(url, options, retries = 5) {
            const delays = [1000, 2000, 4000, 8000, 16000];
            for (let i = 0; i < retries; i++) {
                try {
                    const response = await fetch(url, options);
                    if (!response.ok) {
                        throw new Error(`Error HTTP: ${response.status}`);
                    }
                    return await response.json();
                } catch (error) {
                    if (i === retries - 1) throw error;
                    console.log(`Intento fallido, reintentando en ${delays[i]}ms...`);
                    await new Promise(res => setTimeout(res, delays[i]));
                }
            }
        }

        async function runPromptLab() {
            const basePrompt = document.getElementById('base-prompt').value;
            const ls = document.getElementById('modifier-ls').value;
            const tone = document.getElementById('modifier-tone').value;
            const format = document.getElementById('modifier-format').value;

            if (!basePrompt.trim()) {
                alert("Por favor, escribe una idea básica primero.");
                return;
            }

            // Actualizar UI para mostrar estado de carga
            document.getElementById('lab-empty').classList.add('hidden');
            document.getElementById('lab-results').classList.add('hidden');
            document.getElementById('lab-loading').classList.remove('hidden');
            document.getElementById('lab-loading').classList.add('flex');
            document.getElementById('error-message').classList.add('hidden');
            document.getElementById('btn-optimize').disabled = true;
            document.getElementById('btn-optimize').classList.add('opacity-50', 'cursor-not-allowed');

            const systemInstruction = `Eres un experto en 'Prompt Engineering' para ChatGPT y LLMs. 
            El usuario te dará una idea básica y unos modificadores. 
            Tu tarea es doble:
            1. Reescribir el prompt del usuario aplicando las etiquetas de modificadores pedidas (debes incluir literalmente etiquetas como [ELI5] o /human en el texto del prompt propuesto).
            2. Actuar como la IA y responder a ese nuevo prompt optimizado con un EJEMPLO BREVE (máximo 150 palabras) de cómo sería la respuesta.`;

            const userQuery = `Idea básica del usuario: "${basePrompt}"
            Aplicar estos atajos: Nivel de complejidad: ${ls}, Tono: ${tone}, Formato: ${format}.
            
            Por favor, devuelve un JSON estricto con esta estructura:
            {
                "optimized_prompt": "El texto del prompt perfecto y mejorado usando las etiquetas",
                "example_response": "El texto HTML (usa <br>, <strong>, <ul>, etc.) de cómo respondería el LLM a ese prompt."
            }`;

            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: userQuery }] }],
                systemInstruction: { parts: [{ text: systemInstruction }] },
                generationConfig: {
                    responseMimeType: "application/json",
                    responseSchema: {
                        type: "OBJECT",
                        properties: {
                            optimized_prompt: { type: "STRING" },
                            example_response: { type: "STRING" }
                        }
                    }
                }
            };

            try {
                const result = await fetchWithRetry(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const contentText = result.candidates?.[0]?.content?.parts?.[0]?.text;
                if (contentText) {
                    const data = JSON.parse(contentText);
                    document.getElementById('result-prompt').textContent = data.optimized_prompt;
                    document.getElementById('result-response').innerHTML = data.example_response;
                    
                    document.getElementById('lab-loading').classList.add('hidden');
                    document.getElementById('lab-loading').classList.remove('flex');
                    document.getElementById('lab-results').classList.remove('hidden');
                    document.getElementById('lab-results').classList.add('flex');
                }
            } catch (error) {
                console.error("Error al llamar a Gemini API:", error);
                document.getElementById('error-message').classList.remove('hidden');
                document.getElementById('lab-loading').classList.add('hidden');
                document.getElementById('lab-empty').classList.remove('hidden');
            } finally {
                document.getElementById('btn-optimize').disabled = false;
                document.getElementById('btn-optimize').classList.remove('opacity-50', 'cursor-not-allowed');
            }
        }
    </script>
</body>
</html>
